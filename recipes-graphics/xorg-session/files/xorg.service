[Unit]
Description=Systemd Xorg Session
Before=step-spu.service
After=systemd-user-sessions.service systemd-logind.service

[Service]
User=@SPU_USER@
Group=@SPU_USER@
SupplementaryGroups=video render input
Environment=DISPLAY=:0
TTYPath=/dev/tty1
#StandardInput=tty
StandardOutput=journal
StandardError=journal
ExecStart=/usr/bin/Xorg :0 vt3 -keeptty -nolisten tcp -noreset
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
