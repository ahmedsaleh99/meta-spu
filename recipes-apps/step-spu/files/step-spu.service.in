[Unit]
Description=STEP-SPU Qt App
After=xorg.service network.target
Requires=xorg.service

[Service]
User=@SPU_USER@
Group=@SPU_USER@
WorkingDirectory=@SPU_WORK_DIR@
TTYPath=/dev/tty1
StandardOutput=journal
StandardError=journal
ExecStart=@SPU_APP@
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target